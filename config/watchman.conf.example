# config/watchman.conf.example — committed template.
#
# install.sh detects the family/profile and writes the real config/watchman.conf
# (which is GITIGNORED). This file holds NO secrets — SMTP credentials live only
# in .env. It is plain shell, sourced by lib/profile.sh and the dispatcher.

# --- Identity ---------------------------------------------------------------
# Set by install.sh; override here if detection was wrong.
WATCHMAN_PROFILE=workstation     # server | workstation
WATCHMAN_FAMILY=                 # debian | rhel | arch  (blank = auto-detect from /etc/os-release)
WATCHMAN_USER=root               # claude-watchman runs as root (no dedicated service user)

# --- Loop thresholds --------------------------------------------------------
# The loop emails only when the delta crosses these. A quiet machine stays quiet.
WATCHMAN_NOTIFY_MIN_SEVERITY=high   # email when a NEW finding is >= this severity
WATCHMAN_NOTIFY_ON_REGRESSION=yes   # always email when a fixed finding REGRESSES
WATCHMAN_NOTIFY_ON_NEW_OUTBOUND=yes # (workstation) email on new outbound destinations

# --- Capacity baselines -----------------------------------------------------
WATCHMAN_DISK_WARN_PCT=85           # disk usage % that raises a capacity finding
WATCHMAN_DISK_CRIT_PCT=95           # disk usage % that is DANGEROUSLY low: escalates the finding to critical (red)
WATCHMAN_INODE_WARN_PCT=85
WATCHMAN_INODE_CRIT_PCT=95          # inode usage % that is dangerously low: escalates to critical (red)
WATCHMAN_MEM_WARN_PCT=90
# When a disk is in the danger band, the report lists the biggest files filling it:
WATCHMAN_TOPFILES_COUNT=20          # how many largest files to list
WATCHMAN_TOPFILES_MIN=+25M          # ignore files smaller than this (find -size syntax)

# --- Self-data retention (keep claude-watchman's own footprint bounded) -----
# check-data-footprint sizes the data claude-watchman itself collects under journal/
# (the findings DB, the headless run.log, the cost ledger, db backups, monitor-state)
# and raises a review-tier finding when it grows past the cap OR holds data past these
# windows. It NEVER deletes — pruning is the operator's confirmed call under
# `watchman fix` (journal_prune for DB rows, retention_prune_files for files), which
# backs up findings.db first. Active findings (open/regressed/in-review) are never pruned.
WATCHMAN_DATA_FOOTPRINT_WARN_MB=50   # journal/ total at/over this (MB) raises the finding
WATCHMAN_RETAIN_FINDINGS_DAYS=180    # prune terminal (fixed/ignored) findings last seen older than this
WATCHMAN_RETAIN_METRICS_DAYS=90      # prune metrics time-series rows older than this
WATCHMAN_RETAIN_RUNS_DAYS=90         # prune run rows older than this
WATCHMAN_RETAIN_RUNLOG_MB=10         # rotate run.log (keep recent tail) when larger than this
WATCHMAN_RETAIN_RUNLOG_LINES=2000    # how many recent lines of run.log to keep on rotation
WATCHMAN_RETAIN_BACKUPS=5            # keep this many newest findings.db.backup-* files
WATCHMAN_RETAIN_MONITOR_DAYS=30      # prune journal/monitor-state snapshots older than this
# Note: run-ledger.tsv is REPORTED but never auto-pruned — it feeds the lifetime cost summary.

# --- Security currency (keep defenses current) ------------------------------
# check-security-currency flags stale defenses with the exact update command (it
# never applies one): a stale package DB, pending security updates, known-CVE
# packages, old ClamAV/AIDE/CrowdSec-hub data, and auto-update mechanisms that are off.
WATCHMAN_UPDATE_STALE_DAYS=30      # package metadata older than this (days) = stale view of updates
WATCHMAN_SIG_STALE_DAYS=7          # ClamAV/threat-intel signatures older than this (days) = stale

# --- Security tooling discovery (adopt the box's own defenses) --------------
# inventory-security-tools discovers the defensive tools already installed (fail2ban,
# sshguard, CrowdSec, rkhunter, chkrootkit, auditd, ClamAV, AIDE, debsecan/arch-audit,
# wazuh/ossec), reports whether each is actually effective, and flags a whole CLASS of
# defense that is missing (brute-force protection, rootkit checking, host audit,
# file-integrity baseline). It never installs or enables anything — gaps are manual-tier.
WATCHMAN_FLAG_AV_ABSENT=no         # also flag a MISSING antivirus engine (ClamAV) — off by default (noisy on a typical Linux server; turn on for mail/file servers)

# --- I/O courtesy (never degrade a busy server) -----------------------------
# claude-watchman's heavy reads (integrity verify, full log scans, Lynis, journald
# walks) run at a priority set by its ROLE, and are SKIPPED ("deferred") when the box
# is under real I/O pressure (measured by the kernel's /proc/pressure/io PSI where
# available, else per-core load). It also records its OWN cost per check. So a
# diagnostic can never take a high-use server down — yet on a dedicated monitor it
# can be told to keep running. See lib/io-courtesy.sh.
WATCHMAN_PRIORITY=guest            # guest (yield to everything) | peer | priority (claude-watchman is the critical workload)
WATCHMAN_IONICE=yes                # apply the role's ionice/nice priority to heavy commands
WATCHMAN_IO_TIMEOUT=300            # wall-clock cap (seconds) on a heavy command
WATCHMAN_IO_GUARD=yes              # defer heavy diagnostics when the box is under pressure
WATCHMAN_IO_GUARD_PSI=20           # defer when /proc/pressure/io 'some avg10' exceeds this % (PSI kernels; scaled by role)
WATCHMAN_IO_GUARD_LOAD=1.5         # per-core 1-min load to defer at when PSI is unavailable
WATCHMAN_IO_GUARD_MEM_PCT=10       # defer when available memory drops below this %
WATCHMAN_CHECK_TIME_BUDGET=120     # a check taking longer than this (s) is flagged as expensive (self-footprint)
WATCHMAN_LOG_INCREMENTAL=yes       # loop log/rate scans read only NEW lines since last pass (offsets in journal/log-offsets.txt); 'no' = full scan each time

# --- Inbound rate / DDoS detection (server) ---------------------------------
# inspect-logs flags a single source IP whose PEAK requests-in-one-minute (from
# the web access logs) reaches this, as a high-severity security finding with a
# ready firewall_deny proposal (review-tier — applied only by `watchman fix`,
# never the loop). Tune per site: a busy CDN-fronted site may need it higher.
WATCHMAN_RATE_PER_MIN=300

# --- Safe-tier auto-remediation (opt-in, off by default) --------------------
# Even when 'yes', this only matters for the operator-run `watchman fix`. The
# unattended loop can NEVER apply a fix: its allowlist excludes mutating actions
# and there is no operator to confirm. review/manual are NEVER auto-applied.
WATCHMAN_SAFE_AUTOFIX=no
