# .env.example — SMTP relay for claude-watchman reports.
#
# Copy to .env and fill in. .env is GITIGNORED and is the SINGLE source of mail
# credentials; lib/smtp.sh is the only code that reads it. Never put secrets in
# config/watchman.conf and never hardcode them in a skill.
#
# install.sh copies this template to .env if one does not exist and prompts you
# to fill it in. If SMTP_PASS is left blank, mail dispatch degrades gracefully
# (the loop logs "unconfigured" and skips sending) rather than crashing.
#
# Comments must stay on their own lines: values are read byte-faithfully, so a
# trailing "# note" on a KEY=VALUE line would become part of the value.

# relay hostname
SMTP_HOST=smtp.example.com
# 587 = STARTTLS, 465 = implicit TLS
SMTP_PORT=587
# auth user; also the From: address
SMTP_USER=watchman@example.com
# app password / relay secret — leave blank in the template
SMTP_PASS=
# where reports are sent (the operator's inbox)
REPORT_EMAIL=ops@example.com
